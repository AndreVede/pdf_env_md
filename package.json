        "marked": "^18.0.5",
        "marked-footnote": "^1.4.0",
        "md-to-pdf": "^5.2.5",
        "prettier": "^3.8.3",
        "pug": "^3.0.4",
        "sass": "^1.100.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.16"
    },
    "license": "BSD-3-Clause",
    "dependencies": {
        "baseline-browser-mapping": "^2.10.34",
        "caniuse-lite": "^1.0.30001797"
